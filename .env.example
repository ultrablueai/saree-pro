# Core application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
OWNER_ACCESS_CODE=replace-with-a-secure-owner-code

# Database
# Local development can use SQLite. Production should use managed Postgres.
DATABASE_URL="file:./dev.db"
# DATABASE_POSTGRES_URL="postgresql://user:password@host:5432/sareepro"

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Realtime chat
NEXT_PUBLIC_CHAT_WS_URL=ws://localhost:8080

# Redis cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Monitoring
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=